#!/bin/bash

options="袟邪胁械褉褕械薪懈械 褋械邪薪褋邪\n袩械褉械蟹邪谐褉褍蟹泻邪\n袙褘泻谢褞褔械薪懈械\n小锌褟褖懈泄 褉械卸懈屑\n袘谢芯泻懈褉芯胁泻邪"

selected=$(echo -e "$options" | wofi --dmenu --prompt="袛械泄褋褌胁懈械:")

case $selected in
    "袟邪胁械褉褕械薪懈械 褋械邪薪褋邪")
        swaymsg exit
        ;;
    "袩械褉械蟹邪谐褉褍蟹泻邪")
        systemctl reboot
        ;;
    "袙褘泻谢褞褔械薪懈械")
        systemctl poweroff
        ;;
    "小锌褟褖懈泄 褉械卸懈屑")
        systemctl suspend
        ;;
    "袘谢芯泻懈褉芯胁泻邪")
        swaylock --config ~/.config/swaylock/config
        ;;
esac
